# Database (Neon)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
TZ=America/Argentina/Cordoba

# Sentry (optional — if unset, Sentry init is skipped silently)
# DSN is exposed in the client bundle (the same value goes in both vars).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Build-time only — used by withSentryConfig to upload source maps.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Optional: override environment label sent to Sentry (otherwise uses VERCEL_ENV).
SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
